flowchart TB
    App["App.razor<br/>(Root Blazor Component)"]
    
    subgraph Frontend["Frontend Components"]
        Layout["Layout<br/>(MainLayout.razor)"]
        PageHome["Home Page<br/>(Home.razor)"]
        PageLeaderboard["Leaderboard Page<br/>(Leaderboard.razor)"]
        PageDiag["Diagnostics Page<br/>(Diag.razor)"]
        
        subgraph JesterComponents["Jester Stage Components"]
            JesterStage["JesterStage.razor<br/>(Stage Manager)"]
            JokeCard["JokeCard.razor<br/>(Joke Display)"]
            Commentary["CommentaryBubble.razor<br/>(AI Commentary)"]
            SpeechlessJester["SpeechlessJester.razor<br/>(Fallback)"]
        end
        
        subgraph PerfComponents["Performance Components"]
            PerfDisplay["PerformanceDisplay.razor<br/>(Metrics)"]
            PerfControls["PerformanceControls.razor<br/>(Settings)"]
            PerfOrchestrator["PerformanceOrchestrator.cs<br/>(Logic)"]
        end
        
        subgraph UtilComponents["Utility Components"]
            SafeToggle["SafeModeToggle.razor<br/>(Settings)"]
            SessionStats["SessionStats.razor<br/>(Stats)"]
            NetworkAwaiting["NetworkAwaiting.razor<br/>(Loading)"]
        end
    end
    
    subgraph Backend["Backend Services"]
        JokeEndpoint["Jokes Endpoint<br/>(GET /jokes)"]
        AnalysisEndpoint["Analysis Endpoint<br/>(POST /analysis)"]
        LeaderboardEndpoint["Leaderboard Endpoint<br/>(GET /leaderboards)"]
        DiagnosticsEndpoint["Diagnostics Endpoint<br/>(GET /diagnostics)"]
        HealthEndpoint["Health Endpoint<br/>(GET /health)"]
    end
    
    subgraph Services["Core Services"]
        JokeService["IJokeService<br/>(Joke Fetching)"]
        AnalysisService["IAnalysisService<br/>(AI Analysis)"]
        AudioService["IAudioService<br/>(TTS & Sounds)"]
        SpeechService["ISpeechService<br/>(Voice Synthesis)"]
        StorageClient["IJokeStorageClient<br/>(Persistence)"]
    end
    
    subgraph ExternalAPIs["External APIs"]
        JokeAPI["JokeAPI<br/>(Joke Source)"]
        OpenAI["Azure OpenAI<br/>(GPT-4 Analysis)"]
        TableStorage["Azure Table Storage<br/>(Data Persistence)"]
        KeyVault["Azure Key Vault<br/>(Secrets)"]
    end
    
    subgraph Middleware["Middleware & Cross-Cutting"]
        Resilience["Polly Resilience<br/>(Retries, Timeouts)"]
        Telemetry["OpenTelemetry<br/>(Metrics, Tracing)"]
        Logging["Serilog<br/>(Structured Logging)"]
        HealthChecks["Health Checks<br/>(Dependency Status)"]
    end
    
    App --> Layout
    Layout --> PageHome
    Layout --> PageLeaderboard
    Layout --> PageDiag
    
    PageHome --> JesterStage
    JesterStage --> JokeCard
    JokeCard --> Commentary
    JokeCard --> SpeechlessJester
    PageHome --> PerfDisplay
