    PageHome --> SessionStats
    PageHome --> NetworkAwaiting
    PerfDisplay --> PerfOrchestrator
    PerfControls --> PerfOrchestrator
    
    JesterStage --> JokeEndpoint
    JesterStage --> AnalysisEndpoint
    PageLeaderboard --> LeaderboardEndpoint
    PageDiag --> DiagnosticsEndpoint
    PageDiag --> HealthEndpoint
    
    JokeEndpoint --> JokeService
    AnalysisEndpoint --> AnalysisService
    JokeCard --> AudioService
    AnalysisService --> SpeechService
    StorageClient -.-> LeaderboardEndpoint
    
    JokeService --> JokeAPI
    AnalysisService --> OpenAI
    StorageClient --> TableStorage
    StorageClient --> KeyVault
    JokeService --> Resilience
