flowchart TB
    Start([User Opens Browser<br/>http://localhost:5123])
    
    Home["✨ Home Page<br/>(JesterStage)"]
    
    FetchJoke["🎭 Fetch Joke<br/>from JokeAPI"]
    DisplaySetup["📜 Display Setup<br/>(First part of joke)"]
    
    DramaWait["⏳ Drama Pause<br/>(Suspense)"]
    
    PredictFlow["🤔 AI Predicts Punchline<br/>(Azure OpenAI)"]
    DisplayPrediction["💭 Show Prediction<br/>(with confidence)"]
    
    RevealFlow["🎉 Reveal True Punchline<br/>(JokeAPI data)"]
    PlayAudio["🎙️ Text-to-Speech<br/>(British voice narration)"]
    PlaySound["🎵 Audio Effects<br/>(drums/trombone)"]
    
    RateFlow["⭐ AI Rates Joke<br/>(5 dimensions)"]
    DisplayRating["📊 Show Rating<br/>(Cleverness, Rudeness, etc)"]
    
    StoreJoke["💾 Store to Leaderboard<br/>(Azure Table Storage)"]
    
    Navigation["🗺️ Navigation Menu<br/>Home | Leaderboard | Diagnostics"]
    
    Leaderboard["📋 Leaderboard Page<br/>(Browse joke history)"]
    Diagnostics["🏥 Diagnostics Page<br/>(Health checks)"]
    
    Loop["↩️ Loop to Next Joke<br/>(Autonomous cycle)"]
    
    Start --> Home
    Home --> Navigation
    Navigation -->|Click Home| FetchJoke
    Navigation -->|Click Leaderboard| Leaderboard
    Navigation -->|Click Diagnostics| Diagnostics
    
    FetchJoke --> DisplaySetup
    DisplaySetup --> DramaWait
    DramaWait --> PredictFlow
    PredictFlow --> DisplayPrediction
    DisplayPrediction --> RevealFlow
    RevealFlow --> PlayAudio
    PlayAudio --> PlaySound
    PlaySound --> RateFlow
    RateFlow --> DisplayRating
    DisplayRating --> StoreJoke
    StoreJoke --> Loop
    Loop --> FetchJoke
    
    Leaderboard -->|Sort/Filter| Leaderboard
    Leaderboard -->|Back| Home
    
    Diagnostics -->|Check Status| Diagnostics
    Diagnostics -->|Back| Home
    
