{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "kill-dotnet",
			"type": "process",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"Get-Process dotnet -ErrorAction SilentlyContinue | Stop-Process -Force -ErrorAction SilentlyContinue; exit 0"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent",
				"echo": false
			}
		},
		{
			"label": "run-app",
			"command": "dotnet",
			"type": "process",
			"dependsOrder": "sequence",
			"dependsOn": [
				"kill-dotnet"
			],
			"args": [
				"run",
				"--project",
				"${workspaceFolder}/src/Po.Joker/Po.Joker.csproj"
			],
			"options": {
				"env": {
					"ASPNETCORE_ENVIRONMENT": "Development"
				}
			},
			"problemMatcher": [
				{
					"pattern": [
						{
							"regexp": "^\\s*(.*?)\\((\\d+,\\d+)\\):\\s+(error|warning)\\s+(\\w+):\\s+(.*)$",
							"file": 1,
							"location": 2,
							"severity": 3,
							"code": 4,
							"message": 5
						}
					],
					"background": {
						"activeOnStart": true,
						"beginsPattern": "^Build started",
						"endsPattern": "Now listening on:"
					}
				}
			],
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"echo": true
			}
		},
		{
			"label": "build",
			"command": "dotnet",
			"type": "process",
			"dependsOrder": "sequence",
			"dependsOn": [
				"kill-dotnet"
			],
			"args": [
				"build",
				"${workspaceFolder}/PoJoker.sln",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary;ForceNoAlign"
			],
			"problemMatcher": "$msCompile",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "test",
			"command": "dotnet",
			"type": "process",
			"args": [
				"test",
				"${workspaceFolder}/PoJoker.sln",
				"--no-build"
			],
			"problemMatcher": "$msCompile",
			"group": "test"
		},
		{
			"label": "watch",
			"command": "dotnet",
			"type": "process",
			"args": [
				"watch",
				"run",
				"--project",
				"${workspaceFolder}/src/Po.Joker/Po.Joker.csproj"
			],
			"problemMatcher": "$msCompile",
			"isBackground": true
		}
	]
}