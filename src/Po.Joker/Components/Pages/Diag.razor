@page "/diag"
@inject HttpClient Http
@using Po.Joker.DTOs

<PageTitle>Diagnostics - PoJoker</PageTitle>

<div class="diag-container">
    <div class="diag-header">
        <h1>🔧 Service Health</h1>
        <p class="diag-subtitle">Live connectivity status for all app dependencies</p>
    </div>

    @if (_isLoading)
    {
        <div class="loading-state">
            <div class="loading-spinner"></div>
            <p>Checking connections...</p>
        </div>
    }
    else if (_diagnostics is not null)
    {
        <div class="diag-overview">
            <div class="overall-status @GetOverallStatusClass(_diagnostics.Status)">
                <span class="status-dot"></span>
                <span class="status-text">@_diagnostics.Status</span>
            </div>
            <div class="overview-meta">
                <span>@_diagnostics.Environment</span>
                <span>Up @FormatUptime(_diagnostics.Uptime)</span>
                <span>@_diagnostics.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
            </div>
        </div>

        <div class="services-grid">
            @foreach (var svc in _diagnostics.Services)
            {
                <div class="service-card @GetStatusClass(svc.Status)">
                    <div class="service-icon">@GetServiceIcon(svc.Name)</div>
                    <div class="service-info">
                        <div class="service-name">@svc.Name</div>
                        <div class="service-status">@svc.Status</div>
                        @if (svc.ResponseTimeMs > 0)
                        {
                            <div class="service-latency">@svc.ResponseTimeMs ms</div>
                        }
                        @if (!string.IsNullOrEmpty(svc.Message))
                        {
                            <div class="service-message">@svc.Message</div>
                        }
                    </div>
                    <div class="service-indicator"></div>
                </div>
            }
        </div>

        <div class="stats-row">
            <div class="stat-chip">
                <span class="stat-num">@_diagnostics.TotalJokesServed</span>
                <span class="stat-lbl">Jokes Served</span>
            </div>
            <div class="stat-chip">
                <span class="stat-num">@_diagnostics.TotalAnalyses</span>
                <span class="stat-lbl">AI Analyses</span>
            </div>
            <div class="stat-chip">
                <span class="stat-num">@(_diagnostics.TriumphRate.ToString("P0"))</span>
                <span class="stat-lbl">Triumph Rate</span>
            </div>
        </div>

        <div class="actions-section">
            <button class="refresh-button" @onclick="RefreshDiagnostics">
                🔄 Refresh
            </button>
        </div>
    }
    else if (_error is not null)
    {
        <div class="error-state">
            <span class="error-icon">⚠️</span>
            <p>@_error</p>
            <button class="retry-button" @onclick="RefreshDiagnostics">Try Again</button>
        </div>
    }
</div>

@code {
    private DiagnosticsDto? _diagnostics;
    private bool _isLoading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await RefreshDiagnostics();
    }

    private async Task RefreshDiagnostics()
    {
        _isLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _diagnostics = await Http.GetFromJsonAsync<DiagnosticsDto>("/api/diagnostics/");
        }
        catch (Exception ex)
        {
            _error = $"Failed to retrieve diagnostics: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetStatusClass(HealthStatus status) => status switch
    {
        HealthStatus.Healthy   => "status-healthy",
        HealthStatus.Degraded  => "status-degraded",
        HealthStatus.Unhealthy => "status-unhealthy",
        _                      => "status-unhealthy"
    };

    private static string GetOverallStatusClass(HealthStatus status) => status switch
    {
        HealthStatus.Healthy   => "overall-healthy",
        HealthStatus.Degraded  => "overall-degraded",
        HealthStatus.Unhealthy => "overall-unhealthy",
        _                      => "overall-unhealthy"
    };

    private static string GetServiceIcon(string name) => name.ToLowerInvariant() switch
    {
        var n when n.Contains("openai") || n.Contains("ai") => "🤖",
        var n when n.Contains("joke")                       => "🎭",
        var n when n.Contains("storage") || n.Contains("table") => "🗄️",
        _ => "🔌"
    };

    private static string FormatUptime(TimeSpan uptime)
    {
        if (uptime.TotalDays >= 1)  return $"{(int)uptime.TotalDays}d {uptime.Hours}h";
        if (uptime.TotalHours >= 1) return $"{(int)uptime.TotalHours}h {uptime.Minutes}m";
        return $"{uptime.Minutes}m {uptime.Seconds}s";
    }
}
